generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  avatar        String?
  faceId        String?   @unique  // Link ke ZFace face_id
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  appLinks      UserApp[]
  activities    Activity[]
  affiliatePartner AffiliatePartner?
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserApp {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  @@unique([userId, appId])
}

model App {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  icon        String?
  url         String
  color       String    @default("#2563eb")
  category    String    @default("general")
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  userApps    UserApp[]
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  detail    String?
  appSlug   String?
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([createdAt])
}

model QrSession {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid()) // token di dalam QR code
  status      QrStatus  @default(PENDING)
  userId      String?   // diisi saat HP approve
  userEmail   String?   // diisi saat HP approve
  userName    String?   // diisi saat HP approve
  userRole    String?   // diisi saat HP approve
  expiresAt   DateTime  // QR berlaku 60 detik
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  @@index([token])
  @@index([expiresAt])
}

enum QrStatus {
  PENDING   // QR ditampilkan, belum di-scan
  SCANNED   // HP sudah scan, menunggu konfirmasi user
  APPROVED  // User tap "Izinkan" di HP
  EXPIRED   // QR kedaluwarsa
  CANCELLED // User tap "Tolak" di HP
}

enum Role {
  USER
  ADMIN
}

enum AffiliateType {
  MITRA_LAPANGAN
  CUSTOMER_REFERRAL
}

model AffiliatePartner {
  id             String        @id @default(cuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name           String
  type           AffiliateType
  referralCode   String        @unique
  commissionRate Decimal       @db.Decimal(5, 2)
  balance        Decimal       @default(0) @db.Decimal(12, 2)
  bankAccount    String?
  bankName       String?
  status         String        @default("ACTIVE")
  createdAt      DateTime      @default(now())

  transactions   CommissionTransaction[]
}

model CommissionTransaction {
  id                 String           @id @default(cuid())
  affiliatePartnerId String
  affiliatePartner   AffiliatePartner @relation(fields: [affiliatePartnerId], references: [id], onDelete: Cascade)
  
  type               String           // "EARNED" | "PAYOUT"
  amount             Decimal          @db.Decimal(12, 2)
  notes              String?
  createdBy          String
  createdAt          DateTime         @default(now())
  
  @@index([affiliatePartnerId])
  @@index([createdAt])
}
