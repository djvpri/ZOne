generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  avatar        String?
  role          Role      @default(USER)
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  appLinks      UserApp[]
  activities    Activity[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserApp {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  @@unique([userId, appId])
}

model App {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  icon        String?
  url         String
  color       String    @default("#2563eb")
  category    String    @default("general")
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  userApps    UserApp[]
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  detail    String?
  appSlug   String?
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([createdAt])
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}
